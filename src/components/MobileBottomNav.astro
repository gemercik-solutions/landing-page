---
const navItems = [
  { name: 'Beranda', nameEn: 'Home', href: '#hero', icon: 'home' },
  { name: 'Layanan', nameEn: 'Services', href: '#services', icon: 'services' },
  { name: 'Tentang', nameEn: 'About', href: '#about', icon: 'about' },
  { name: 'FAQ', nameEn: 'FAQ', href: '#faq', icon: 'faq' },
  { name: 'Kontak', nameEn: 'Contact', href: '#contact', icon: 'contact' },
];
---

<nav
  id="mobile-bottom-nav"
  class="bottom-nav fixed bottom-0 left-0 right-0 z-[100] md:hidden flex justify-center"
  aria-label="Navigasi utama"
>
  <div class="bottom-nav__bar w-full max-w-[480px] mx-auto">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="bottom-nav__item nav-link group"
        data-id={item.name}
        data-en={item.nameEn}
        data-href={item.href}
      >
        <span class="bottom-nav__icon">
          {item.icon === 'home' && (
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m0 0l7-7-7 7m0 0l-7 7M14 10v10a1 1 0 01-1 1h-3" />
            </svg>
          )}
          {item.icon === 'services' && (
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          )}
          {item.icon === 'about' && (
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          )}
          {item.icon === 'faq' && (
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          )}
          {item.icon === 'contact' && (
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          )}
        </span>
        <span class="bottom-nav__label nav-text">{item.name}</span>
      </a>
    ))}
  </div>
</nav>

<style>
  .bottom-nav {
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .bottom-nav__bar {
    display: flex;
    list-style: none;
    margin: 0;
    width: 100%;
    max-width: 100%;
    padding: 0.5rem 0.25rem 0.75rem;
    gap: 0.25rem;
    align-items: center;
    justify-content: space-around;
    text-align: center;
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1.25;
    text-decoration: none;

    /* Theme: dark glass with primary/secondary accent */
    background: linear-gradient(
      180deg,
      rgba(2, 6, 23, 0.97) 0%,
      rgba(15, 23, 42, 0.98) 100%
    );
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(14, 165, 233, 0.25);
    box-shadow:
      0 -4px 24px rgba(0, 0, 0, 0.2),
      0 -1px 0 rgba(251, 191, 36, 0.08);
  }

  .light .bottom-nav__bar {
    background: linear-gradient(
      180deg,
      rgba(248, 250, 252, 0.97) 0%,
      rgba(241, 245, 249, 0.98) 100%
    );
    border-top: 1px solid rgba(2, 132, 199, 0.2);
    box-shadow:
      0 -4px 24px rgba(0, 0, 0, 0.06),
      0 -1px 0 rgba(251, 191, 36, 0.12);
  }

  .bottom-nav__item {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-width: 0;
    padding: 0.25rem 0.125rem 0;
    color: var(--color-dark-400);
    transition: color 0.2s ease;
    border-radius: 0.5rem;
  }

  .bottom-nav__item:hover,
  .bottom-nav__item:focus {
    color: var(--color-primary-400);
  }

  .bottom-nav__item[data-active="true"] {
    color: var(--color-primary-400);
  }

  .light .bottom-nav__item {
    color: var(--color-dark-500);
  }

  .light .bottom-nav__item:hover,
  .light .bottom-nav__item:focus,
  .light .bottom-nav__item[data-active="true"] {
    color: var(--color-primary-600);
  }

  .bottom-nav__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    margin-bottom: 0.125rem;
  }

  .bottom-nav__icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .bottom-nav__label {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
</style>

<script>
  // Set active item based on scroll position / hash
  function setActiveBottomNav() {
    const nav = document.getElementById('mobile-bottom-nav');
    if (!nav) return;
    const items = nav.querySelectorAll('.bottom-nav__item');
    const sections = ['hero', 'services', 'about', 'faq', 'contact'];
    const scrollY = window.scrollY;
    const viewportMid = scrollY + window.innerHeight / 2;
    let activeIndex = 0;
    sections.forEach((id, i) => {
      const el = document.getElementById(id);
      if (el) {
        const top = el.offsetTop;
        const bottom = top + el.offsetHeight;
        if (viewportMid >= top && viewportMid <= bottom) activeIndex = i;
      }
    });
    items.forEach((item, i) => {
      item.setAttribute('data-active', i === activeIndex ? 'true' : 'false');
    });
  }

  window.addEventListener('scroll', setActiveBottomNav, { passive: true });
  window.addEventListener('load', setActiveBottomNav);
  window.addEventListener('hashchange', () => setTimeout(setActiveBottomNav, 100));

  function updateBottomNavLabels(lang: string) {
    document.querySelectorAll('#mobile-bottom-nav .nav-link').forEach((link) => {
      const textSpan = link.querySelector('.nav-text');
      const dataId = link.getAttribute('data-id');
      const dataEn = link.getAttribute('data-en');
      if (textSpan && dataId && dataEn) {
        textSpan.textContent = lang === 'id' ? dataId : dataEn;
      }
    });
  }

  window.addEventListener('languageChanged', ((e: CustomEvent) => {
    updateBottomNavLabels(e.detail?.language || 'id');
  }) as EventListener);

  const savedLang = localStorage.getItem('language') || 'id';
  if (savedLang === 'en') updateBottomNavLabels('en');
</script>
