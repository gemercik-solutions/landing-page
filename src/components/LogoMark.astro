---
const { size = 96, alt="Gemercik Solution" } = Astro.props;
---
<div class="logo-wrap" style={`--size:${size}px;`}>
  <img
    src="/images/logo.png"
    alt={alt}
    width={size}
    height={size}
    loading="eager"
    decoding="async"
    class="logo-image"
  />
  <span class="shine" aria-hidden="true"></span>
</div>

<style>
.logo-wrap{
  position:relative;
  width:var(--size);
  height:var(--size);
  border-radius:999px;
  filter: drop-shadow(0 18px 40px rgba(0,0,0,.35));
  transform: translateZ(0);
  animation: floaty 6.5s ease-in-out infinite;
}
.logo-img{
  width:100%;
  height:100%;
  object-fit:contain;
  border-radius:999px;
  will-change: transform;
  transition: transform .45s cubic-bezier(.2,.8,.2,1);
}
.logo-wrap:hover .logo-img{
  transform: scale(1.03) rotate(-0.6deg);
}

.shine{
  position:absolute;
  inset:-25%;
  background: linear-gradient(
    120deg,
    transparent 40%,
    rgba(245,248,252,.22) 48%,
    rgba(37,223,255,.18) 52%,
    transparent 60%
  );
  transform: translateX(-60%) rotate(10deg);
  animation: shine 4.8s ease-in-out infinite;
  pointer-events:none;
  mix-blend-mode: screen;
}

@keyframes floaty{
  0%,100% { transform: translateY(0) }
  50%     { transform: translateY(-10px) }
}
@keyframes shine{
  0%,55% { opacity:.0; transform: translateX(-60%) rotate(10deg); }
  70%    { opacity:.9; }
  100%   { opacity:0; transform: translateX(55%) rotate(10deg); }
}

@media (prefers-reduced-motion: reduce){
  .logo-wrap, .shine { animation: none !important; }
  .logo-img{ transition:none; }
}
</style>