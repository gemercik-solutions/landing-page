---
---

<section id="contact" class="relative py-20 lg:py-32 bg-linear-to from-primary-500 via-dark-900 to-secondary-500/20 overflow-hidden">
  <!-- Background Decorations -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-secondary-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-block px-4 py-2 bg-primary-500/10 dark:bg-primary-500/10 light:bg-primary-500/20 border border-primary-500/20 dark:border-primary-500/20 light:border-primary-500/30 rounded-full mb-6">
        <span class="text-primary-400 dark:text-primary-400 light:text-primary-600 text-sm font-semibold" data-i18n="contact.badge">HUBUNGI KAMI</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-6">
        <span data-i18n="contact.title1">Mari Wujudkan</span> <span class="text-transparent bg-clip-text bg-linear-to-r from-primary-400 to-secondary-500" data-i18n="contact.title2">Ide Digital</span> <span data-i18n="contact.title3">Anda</span>
      </h2>
      <p class="text-lg text-dark-200" data-i18n="contact.subtitle">
        Konsultasi gratis untuk menentukan solusi terbaik bagi bisnis Anda
      </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
      
      <!-- Left: Contact Form -->
      <div class="bg-dark-800/50 dark:bg-dark-800/50 light:bg-white/80 backdrop-blur-sm border border-dark-700 dark:border-dark-700 light:border-gray-200 rounded-2xl p-8">
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-white dark:text-white light:text-dark-900 font-medium mb-2" data-i18n="contact.nameLabel">Nama Lengkap</label>
            <input 
              type="text" 
              id="name" 
              name="name"
              class="w-full px-4 py-3 bg-dark-900 dark:bg-dark-900 light:bg-gray-50 border border-dark-600 dark:border-dark-600 light:border-gray-300 rounded-lg text-white dark:text-white light:text-dark-900 placeholder-dark-400 dark:placeholder-dark-400 light:placeholder-dark-400 focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all"
              placeholder="John Doe"
              required
            />
          </div>

          <div>
            <label for="email" class="block text-white dark:text-white light:text-dark-900 font-medium mb-2" data-i18n="contact.emailLabel">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email"
              class="w-full px-4 py-3 bg-dark-900 dark:bg-dark-900 light:bg-gray-50 border border-dark-600 dark:border-dark-600 light:border-gray-300 rounded-lg text-white dark:text-white light:text-dark-900 placeholder-dark-400 dark:placeholder-dark-400 light:placeholder-dark-400 focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all"
              placeholder="john@example.com"
              required
            />
          </div>

          <div>
            <label for="phone" class="block text-white dark:text-white light:text-dark-900 font-medium mb-2" data-i18n="contact.phoneLabel">Nomor Telepon</label>
            <input 
              type="tel" 
              id="phone" 
              name="phone"
              class="w-full px-4 py-3 bg-dark-900 dark:bg-dark-900 light:bg-gray-50 border border-dark-600 dark:border-dark-600 light:border-gray-300 rounded-lg text-white dark:text-white light:text-dark-900 placeholder-dark-400 dark:placeholder-dark-400 light:placeholder-dark-400 focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all"
              placeholder="+62 812-3456-7890"
            />
          </div>

          <div>
            <label for="service" class="block text-white dark:text-white light:text-dark-900 font-medium mb-2" data-i18n="contact.serviceLabel">Layanan yang Dibutuhkan</label>
            <select 
              id="service" 
              name="service"
              class="w-full px-4 py-3 bg-dark-900 dark:bg-dark-900 light:bg-gray-50 border border-dark-600 dark:border-dark-600 light:border-gray-300 rounded-lg text-white dark:text-white light:text-dark-900 focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all"
            >
              <option value="" data-i18n="contact.selectService">Pilih Layanan</option>
              <option value="fullstack" data-i18n="contact.fullstack">Fullstack Development</option>
              <option value="mobile" data-i18n="contact.mobile">Mobile Development</option>
              <option value="website" data-i18n="contact.website">Website Development</option>
              <option value="ai" data-i18n="contact.ai">AI Solutions</option>
              <option value="consulting" data-i18n="contact.consulting">Konsultasi</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-white dark:text-white light:text-dark-900 font-medium mb-2" data-i18n="contact.messageLabel">Pesan</label>
            <textarea 
              id="message" 
              name="message"
              rows="4"
              class="w-full px-4 py-3 bg-dark-900 dark:bg-dark-900 light:bg-gray-50 border border-dark-600 dark:border-dark-600 light:border-gray-300 rounded-lg text-white dark:text-white light:text-dark-900 placeholder-dark-400 dark:placeholder-dark-400 light:placeholder-dark-400 focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all resize-none"
              placeholder="Ceritakan tentang proyek Anda..."
              required
            ></textarea>
          </div>

          <button 
            type="submit"
            class="w-full px-8 py-4 bg-linear-to-r from-primary-500 to-primary-600 text-white font-semibold rounded-lg hover:from-primary-600 hover:to-primary-700 transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-primary-500/50 flex items-center justify-center group"
            data-i18n="contact.submit"
          >
            Kirim Pesan
            <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </button>
        </form>
      </div>

      <!-- Right: Contact Info & Map -->
      <div class="space-y-8">
        
        <!-- Contact Cards -->
        <div class="space-y-4">
          
          <!-- WhatsApp -->
          <a 
            href="https://wa.me/6281234567890" 
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start p-6 bg-dark-800/50 dark:bg-dark-800/50 light:bg-white/80 backdrop-blur-sm border border-dark-700 dark:border-dark-700 light:border-gray-200 rounded-xl hover:border-primary-500/50 transition-all duration-300 group"
          >
            <div class="w-12 h-12 rounded-lg bg-linear-to-br from-primary-500/20 to-primary-600/20 dark:from-primary-500/20 dark:to-primary-600/20 light:from-primary-500/30 light:to-primary-600/30 flex items-center justify-center mr-4 shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-primary-400 dark:text-primary-400 light:text-primary-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white dark:text-white light:text-dark-900 font-semibold mb-1" data-i18n="contact.whatsappTitle">WhatsApp (Fast Response)</h3>
              <p class="text-dark-300 dark:text-dark-300 light:text-dark-600">+62 812-3456-7890</p>
            </div>
          </a>

          <!-- Email -->
          <a 
            href="mailto:halo@gemercik.id"
            class="flex items-start p-6 bg-dark-800/50 dark:bg-dark-800/50 light:bg-white/80 backdrop-blur-sm border border-dark-700 dark:border-dark-700 light:border-gray-200 rounded-xl hover:border-primary-500/50 transition-all duration-300 group"
          >
            <div class="w-12 h-12 rounded-lg bg-linear-to-br from-primary-500/20 to-primary-600/20 dark:from-primary-500/20 dark:to-primary-600/20 light:from-primary-500/30 light:to-primary-600/30 flex items-center justify-center mr-4 shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-primary-400 dark:text-primary-400 light:text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white dark:text-white light:text-dark-900 font-semibold mb-1" data-i18n="contact.emailTitle">Email</h3>
              <p class="text-dark-300 dark:text-dark-300 light:text-dark-600">halo@gemercik.id</p>
            </div>
          </a>

          <!-- Address -->
          <div class="flex items-start p-6 bg-dark-800/50 dark:bg-dark-800/50 light:bg-white/80 backdrop-blur-sm border border-dark-700 dark:border-dark-700 light:border-gray-200 rounded-xl">
            <div class="w-12 h-12 rounded-lg bg-linear-to-br from-primary-500/20 to-primary-600/20 dark:from-primary-500/20 dark:to-primary-600/20 light:from-primary-500/30 light:to-primary-600/30 flex items-center justify-center mr-4 shrink-0">
              <svg class="w-6 h-6 text-primary-400 dark:text-primary-400 light:text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white dark:text-white light:text-dark-900 font-semibold mb-1" data-i18n="contact.addressTitle">Alamat Kantor</h3>
              <p class="text-dark-300 dark:text-dark-300 light:text-dark-600">
                <span data-i18n="contact.address1">Digital Hub, Level 5</span><br/>
                <span data-i18n="contact.address2">Green Office Park, BSD City</span><br/>
                <span data-i18n="contact.address3">Tangerang, Indonesia</span>
              </p>
            </div>
          </div>

        </div>

        <!-- Google Maps Embed -->
        <div class="bg-dark-800/50 dark:bg-dark-800/50 light:bg-white/80 backdrop-blur-sm border border-dark-700 dark:border-dark-700 light:border-gray-200 rounded-xl p-2 overflow-hidden">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3965.3826738598847!2d106.63854731476892!3d-6.345164895424764!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69e52c3e8a2c1f%3A0x4c62c7c7c7c7c7c7!2sGreen%20Office%20Park!5e0!3m2!1sen!2sid!4v1609459200000!5m2!1sen!2sid" 
            width="100%" 
            height="300" 
            style="border:0; border-radius: 0.75rem;" 
            allowfullscreen="" 
            loading="lazy"
            class="grayscale hover:grayscale-0 transition-all duration-300"
          ></iframe>
        </div>

      </div>

    </div>

  </div>
</section>

<script>
  import { initLanguage } from '../lib/i18n';
  initLanguage();
  
  // Form submission handler (demo)
  const form = document.querySelector('form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Terima kasih! Pesan Anda telah diterima. Tim kami akan segera menghubungi Anda.');
    form.reset();
  });
</script>
