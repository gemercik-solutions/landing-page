---
import Container from "./ui/Container.astro";
import { SITE } from "../lib/site";
---
<footer class="border-t border-white/10 py-12 mt-24">
  <Container class="grid gap-6 sm:grid-cols-2">
    <div>
      <p class="font-semibold">{SITE.name}</p>
      <p class="mt-2 text-sm opacity-70">
        AI & Automation untuk bisnis yang ingin tumbuh dengan sistem.
      </p>
    </div>
    <div class="text-sm sm:text-right opacity-70">
      <p>Email: {SITE.email}</p>
      <p>WhatsApp: {SITE.whatsapp}</p>
      <p class="mt-4">© {new Date().getFullYear()}</p>
    </div>
  </Container>
</footer>
