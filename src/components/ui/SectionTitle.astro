---
const { eyebrow, title, subtitle } = Astro.props;
---
<div class="mb-12 max-w-2xl">
  {eyebrow && (
    <p class="mb-2 text-sm font-semibold tracking-wide text-cyan-300">
      {eyebrow}
    </p>
  )}
  <h2 class="text-3xl font-semibold sm:text-4xl">{title}</h2>
  {subtitle && (
    <p class="mt-4 text-base opacity-80">{subtitle}</p>
  )}
</div>
