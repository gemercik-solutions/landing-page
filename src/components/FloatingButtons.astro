<!-- Scroll to Top Button -->
<button
  id="scroll-to-top"
  class="fixed bottom-6 right-24 z-50 w-12 h-12 bg-dark-800 dark:bg-dark-800 light:bg-white border border-primary-500/50 dark:border-primary-500/50 light:border-primary-500/30 rounded-full flex items-center justify-center shadow-lg hover:bg-primary-500 dark:hover:bg-primary-500 light:hover:bg-primary-500 hover:border-primary-400 transition-all duration-300 opacity-0 pointer-events-none"
  aria-label="Scroll to top"
>
  <svg
    class="w-6 h-6 text-primary-400 dark:text-primary-400 light:text-primary-600 hover:text-white transition-colors"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
  </svg>
</button>

<script>
  // Scroll to top functionality
  const scrollBtn = document.getElementById("scroll-to-top");

  window.addEventListener("scroll", () => {
    if (window.pageYOffset > 300) {
      scrollBtn?.classList.remove("opacity-0", "pointer-events-none");
      scrollBtn?.classList.add("opacity-100");
    } else {
      scrollBtn?.classList.add("opacity-0", "pointer-events-none");
      scrollBtn?.classList.remove("opacity-100");
    }
  });

  scrollBtn?.addEventListener("click", () => {
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  });
</script>
