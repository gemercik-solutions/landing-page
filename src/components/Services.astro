---
import { services } from '../constants/services';
---

<section id="services" class="relative py-20 lg:py-32 bg-linear-to from-primary-500 via-dark-900 to-secondary-500/20 overflow-hidden transition-colors duration-300">
  <!-- Background Decorations -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/3 left-0 w-72 h-72 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/3 right-0 w-72 h-72 bg-secondary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary-400/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-block px-4 py-2 bg-primary-500/10 dark:bg-primary-500/10 light:bg-primary-500/20 border border-primary-500/20 dark:border-primary-500/20 light:border-primary-500/30 rounded-full mb-6">
        <span class="text-primary-400 dark:text-primary-400 light:text-primary-600 text-sm font-semibold" data-i18n="services.badge">LAYANAN KAMI</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-6">
        <span class="text-dark-200" data-i18n="services.title">Solusi Lengkap untuk</span> <span class="text-transparent bg-clip-text bg-linear-to-r from-primary-400 to-secondary-500" data-i18n="services.titleHighlight">Bisnis Digital</span>
      </h2>
      <p class="text-lg text-dark-200" data-i18n="services.subtitle">
        Kami menyediakan layanan teknologi komprehensif yang dirancang khusus untuk kebutuhan UMKM Indonesia
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-6xl mx-auto">
      {services.map((service, index) => (
        <div 
          class="group relative bg-dark-800/50 dark:bg-dark-800/50 light:bg-white/80 backdrop-blur-sm border border-dark-700 dark:border-dark-700 light:border-gray-200 rounded-2xl p-8 hover:border-primary-500/50 dark:hover:border-primary-500/50 light:hover:border-primary-500 transition-all duration-500 hover:shadow-2xl hover:shadow-primary-500/10 dark:hover:shadow-primary-500/10 light:hover:shadow-primary-500/20 hover:-translate-y-2"
          style={`animation: fade-up 0.6s ease-out forwards; animation-delay: ${index * 0.1}s; opacity: 0;`}
        >
          <!-- Icon -->
          <div class="relative mb-6">
            <div class={`w-16 h-16 rounded-xl bg-linear-to-br ${service.color === 'primary' ? 'from-primary-500/20 to-primary-600/20' : 'from-secondary-500/20 to-secondary-600/20'} flex items-center justify-center group-hover:scale-110 transition-transform duration-300`}>
              {service.icon === 'code' && (
                <svg class="w-8 h-8 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                </svg>
              )}
              {service.icon === 'mobile' && (
                <svg class="w-8 h-8 text-secondary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
              )}
              {service.icon === 'globe' && (
                <svg class="w-8 h-8 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                </svg>
              )}
              {service.icon === 'ai' && (
                <svg class="w-8 h-8 text-secondary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
              )}
            </div>
            <!-- Glow Effect -->
            <div class={`absolute inset-0 w-16 h-16 rounded-xl bg-linear-to-br ${service.color === 'primary' ? 'from-primary-500 to-primary-600' : 'from-secondary-500 to-secondary-600'} opacity-0 group-hover:opacity-20 blur-xl transition-opacity duration-300`}></div>
          </div>

          <!-- Content -->
          <h3 class="text-2xl font-heading font-bold text-white dark:text-white light:text-dark-900 mb-3 group-hover:text-primary-400 transition-colors duration-300" data-i18n={service.titleKey}>
            {service.title}
          </h3>
          <p class="text-dark-200 dark:text-dark-200 light:text-dark-600 mb-6 leading-relaxed" data-i18n={service.descKey}>
            {service.desc}
          </p>

          <!-- Features -->
          <ul class="space-y-2">
            {service.features.map((feature) => (
              <li class="flex items-center text-dark-300 dark:text-dark-300 light:text-dark-700 text-sm">
                <svg class="w-5 h-5 text-primary-400 dark:text-primary-400 light:text-primary-600 mr-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span data-i18n={feature.key}>{feature.text}</span>
              </li>
            ))}
          </ul>

          <!-- Hover Arrow -->
          <div class="absolute bottom-8 right-8 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <a 
        href="#contact" 
        class="inline-flex items-center px-8 py-4 bg-linear-to-r from-primary-500 to-primary-600 text-white font-semibold rounded-lg hover:from-primary-600 hover:to-primary-700 transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-primary-500/50 group"
        data-i18n="services.cta"
      >
        Lihat Semua Layanan
        <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
