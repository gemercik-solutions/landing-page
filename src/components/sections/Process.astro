---
import Container from "../ui/Container.astro";
import SectionTitle from "../ui/SectionTitle.astro";

const steps = [
  ["Discovery", "Audit kebutuhan & bottleneck bisnis"],
  ["Build", "Implementasi AI & automation"],
  ["Deploy", "Monitoring, optimasi & scale"],
];
---
<section id="process" class="py-24 bg-white/5">
  <Container>
    <SectionTitle
      eyebrow="Cara Kerja"
      title="Pendekatan sistematis"
      subtitle="Bukan eksperimen acak. Semua terukur."
    />

    <ol class="grid gap-6 sm:grid-cols-3">
      {steps.map(([title, desc], i) => (
        <li class="rounded-xl border border-white/10 p-6">
          <span class="text-sm text-cyan-300">Step {i + 1}</span>
          <h3 class="mt-2 font-semibold">{title}</h3>
          <p class="mt-2 text-sm opacity-80">{desc}</p>
        </li>
      ))}
    </ol>
  </Container>
</section>
