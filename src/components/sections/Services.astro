---
import Container from "../ui/Container.astro";
import SectionTitle from "../ui/SectionTitle.astro";

const services = [
  {
    title: "AI Finance",
    desc: "Otomatisasi pencatatan, insight keuangan, dan deteksi anomali berbasis data."
  },
  {
    title: "AI Content",
    desc: "Produksi konten cepat & konsisten untuk marketing, produk, dan internal."
  },
  {
    title: "Automation",
    desc: "Integrasi proses bisnis: approval, invoice, reporting, WhatsApp, CRM."
  },
];
---
<section id="services" class="py-24">
  <Container>
    <SectionTitle
      eyebrow="Layanan"
      title="Solusi inti yang kami bangun"
      subtitle="Fokus pada sistem yang berdampak langsung ke operasional."
    />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <h3 class="text-lg font-semibold">{s.title}</h3>
          <p class="mt-3 text-sm opacity-80">{s.desc}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
