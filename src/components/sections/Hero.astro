---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import LogoMark from "../LogoMark.astro";
import { SITE } from "../../lib/site";

const waLink = `https://wa.me/62${SITE.whatsapp.replace(/^0/, "")}?text=${encodeURIComponent(
  "Halo Gemercik Solution, saya ingin konsultasi implementasi AI/Automation untuk bisnis saya."
)}`;
---
<section id="top" class="relative overflow-hidden py-20 sm:py-28">
  <Container>
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <div class="mb-6 flex items-center gap-4">
          <LogoMark size={84} />
          <div class="text-sm opacity-80">
            <div class="font-semibold">Gemercik Solution</div>
            <div>AI • Automation • Digital Systems</div>
          </div>
        </div>

        <h1 class="text-4xl font-semibold leading-tight sm:text-5xl">
          AI yang <span class="text-cyan-300">menghasilkan</span>, automation yang <span class="text-amber-300">menghemat</span>.
        </h1>

        <p class="mt-5 max-w-xl text-base leading-relaxed opacity-85">
          Kami bantu bisnis membangun sistem AI & automation yang rapi: dari discovery,
          build, sampai deploy. Fokus pada dampak: efisiensi operasional, kecepatan eksekusi,
          dan data yang siap dipakai keputusan.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href="#contact" variant="primary">Konsultasi Gratis</Button>
          <Button href={waLink} variant="ghost" target="_blank" rel="noreferrer">
            WhatsApp Sekarang
          </Button>
        </div>

        <div class="mt-8 flex flex-wrap gap-3 text-sm opacity-80">
          <span class="pill">Audit kebutuhan 30 menit</span>
          <span class="pill">Roadmap implementasi</span>
          <span class="pill">Estimasi effort & cost</span>
        </div>
      </div>

      <div class="relative">
        <div class="card-glow">
          <div class="rounded-[24px] border border-white/10 bg-white/5 p-7 shadow-[0_30px_90px_rgba(0,0,0,.35)]">
            <div class="text-sm opacity-80">Preview value delivery</div>
            <div class="mt-3 text-2xl font-semibold">Sistem yang terukur, bukan sekadar “automation coba-coba”.</div>
            <ul class="mt-5 space-y-3 text-sm opacity-85">
              <li>• Integrasi: WhatsApp, Google Sheet, ERP, CRM, marketplace</li>
              <li>• Dashboard: KPI operasional & revenue</li>
              <li>• AI: klasifikasi, summarization, Q&A dokumen, rekomendasi</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </Container>

  <style>
    .pill{
      padding:.55rem .75rem;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.05);
    }
    .card-glow{
      position:relative;
    }
    .card-glow:before{
      content:"";
      position:absolute;
      inset:-40px;
      background: radial-gradient(600px 250px at 30% 20%, rgba(16,114,246,.25), transparent 60%),
                  radial-gradient(500px 240px at 70% 60%, rgba(37,223,255,.18), transparent 60%),
                  radial-gradient(500px 240px at 50% 90%, rgba(249,176,48,.12), transparent 60%);
      filter: blur(10px);
      z-index:-1;
    }
  </style>
</section>
