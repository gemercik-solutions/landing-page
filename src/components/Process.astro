---
import ProcessStep from "./ProcessStep.astro";
import { steps } from "../constants/process";
---

<section
  class="relative py-20 lg:py-32 bg-linear-to-br from-primary-500 via-dark-900 to-secondary-500/20 overflow-hidden"
>
  <!-- Background Pattern -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div
        class="inline-block px-4 py-2 bg-primary-500/10 dark:bg-primary-500/10 light:bg-primary-500/20 border border-primary-500/20 dark:border-primary-500/20 light:border-primary-500/30 rounded-full mb-6"
      >
        <span
          class="text-primary-400 dark:text-primary-400 light:text-primary-600 text-sm font-semibold"
          data-i18n="process.badge">PROSES KERJA</span
        >
      </div>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-6"
      >
        <span data-i18n="process.title1">Cara Kami</span>
        <span
          class="text-transparent bg-clip-text bg-linear-to-r from-primary-400 to-secondary-500"
          data-i18n="process.title2">Bekerja</span
        >
      </h2>
      <p class="text-lg text-dark-200" data-i18n="process.subtitle">
        Proses sederhana dan transparan untuk menghadirkan solusi digital
        terbaik
      </p>
    </div>

    <!-- Process Steps -->
    <div
      class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12"
    >
      {
        steps.map((step, index) => (
          <div
            style={`animation: fade-up 0.6s ease-out forwards; animation-delay: ${index * 0.1}s; opacity: 0;`}
          >
            <ProcessStep {...step} />
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <p class="text-dark-300 dark:text-dark-300 light:text-dark-600 mb-6">
        <span data-i18n="process.timeline">Rata-rata project selesai dalam</span
        >
        <span
          class="text-primary-400 dark:text-primary-400 light:text-primary-600 font-semibold"
          data-i18n="process.duration">2-4 minggu</span
        >
      </p>
      <a
        href="#contact"
        class="inline-flex items-center px-8 py-4 bg-linear-to-r from-primary-500 to-primary-600 text-white font-semibold rounded-lg hover:from-primary-600 hover:to-primary-700 transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-primary-500/50 group"
        data-i18n="process.cta"
      >
        Mulai Project Anda
        <svg
          class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
