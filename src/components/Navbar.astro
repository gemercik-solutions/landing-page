---
import Container from "./ui/Container.astro";
import LogoMark from "./LogoMark.astro";
import Button from "./ui/Button.astro";
---
<header class="sticky top-0 z-50 backdrop-blur-md bg-black/30 border-b border-white/10">
  <Container class="flex h-16 items-center justify-between">
    <a href="#top" class="flex items-center gap-3">
      <LogoMark size={36} />
      <span class="font-semibold">Gemercik Solution</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm">
      <a href="#services" class="opacity-80 hover:opacity-100">Services</a>
      <a href="#process" class="opacity-80 hover:opacity-100">Process</a>
      <a href="#pricing" class="opacity-80 hover:opacity-100">Pricing</a>
      <a href="#contact" class="opacity-80 hover:opacity-100">Contact</a>
    </nav>

    <Button href="#contact">Konsultasi</Button>
  </Container>

</header>