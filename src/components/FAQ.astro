---
import { t } from '../lib/i18n';

const faqs = [
  {
    questionKey: 'faq.q1',
    question: t('faq.q1'),
    answerKey: 'faq.a1',
    answer: t('faq.a1')
  },
  {
    questionKey: 'faq.q2',
    question: t('faq.q2'),
    answerKey: 'faq.a2',
    answer: t('faq.a2')
  },
  {
    questionKey: 'faq.q3',
    question: t('faq.q3'),
    answerKey: 'faq.a3',
    answer: t('faq.a3')
  },
  {
    questionKey: 'faq.q4',
    question: t('faq.q4'),
    answerKey: 'faq.a4',
    answer: t('faq.a4')
  },
  {
    questionKey: 'faq.q5',
    question: t('faq.q5'),
    answerKey: 'faq.a5',
    answer: t('faq.a5')
  },
  {
    questionKey: 'faq.q6',
    question: t('faq.q6'),
    answerKey: 'faq.a6',
    answer: t('faq.a6')
  },
];
---

<section id="faq" class="relative py-20 lg:py-32 bg-linear-to-br from-primary-500 via-dark-900 to-secondary-500/20 overflow-hidden">
  <!-- Background Decorations -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-secondary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-block px-4 py-2 bg-primary-500/10 dark:bg-primary-500/10 light:bg-primary-500/20 border border-primary-500/20 dark:border-primary-500/20 light:border-primary-500/30 rounded-full mb-6">
        <span class="text-primary-400 dark:text-primary-400 light:text-primary-600 text-sm font-semibold" data-i18n="faq.badge">FAQ</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-6">
        <span data-i18n="faq.title1">Pertanyaan yang Sering</span> <span class="text-transparent bg-clip-text bg-linear-to-r from-primary-400 to-secondary-500" data-i18n="faq.title2">Ditanyakan</span>
      </h2>
      <p class="text-lg text-dark-200" data-i18n="faq.subtitle">
        Temukan jawaban untuk pertanyaan umum seputar layanan kami
      </p>
    </div>

    <!-- FAQ Grid -->
    <div class="max-w-4xl mx-auto space-y-4">
      {faqs.map((faq, index) => (
        <div 
          class="faq-item bg-dark-800/50 dark:bg-dark-800/50 light:bg-white/80 backdrop-blur-sm border border-dark-700 dark:border-dark-700 light:border-gray-200 rounded-xl overflow-hidden hover:border-primary-500/50 transition-all duration-300"
          style={`animation: fade-up 0.6s ease-out forwards; animation-delay: ${index * 0.05}s; opacity: 0;`}
        >
          <button 
            class="faq-question w-full px-6 py-5 text-left flex items-center justify-between group"
            aria-expanded="false"
          >
            <span class="text-lg font-semibold text-white dark:text-white light:text-dark-900 pr-8" data-i18n={faq.questionKey}>{faq.question}</span>
            <svg 
              class="faq-icon w-6 h-6 text-primary-400 dark:text-primary-400 light:text-primary-600 transition-transform duration-300 shrink-0" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-5 text-dark-200 dark:text-dark-200 light:text-dark-700 leading-relaxed" data-i18n={faq.answerKey}>
              {faq.answer}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Still have questions? -->
    <div class="text-center mt-12">
      <p class="text-dark-300 dark:text-dark-300 light:text-dark-600 mb-4" data-i18n="faq.question">Masih ada pertanyaan lain?</p>
      <a 
        href="https://wa.me/6281310363949?text=Halo%20Gemercik%20Solution!%20Saya%20ingin%20bertanya" 
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center text-primary-400 dark:text-primary-400 light:text-primary-600 hover:text-primary-300 dark:hover:text-primary-300 light:hover:text-primary-700 font-semibold transition-colors"
        data-i18n="faq.contact"
      >
        Hubungi kami via WhatsApp
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // FAQ Accordion functionality
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question');
      const answer = item.querySelector('.faq-answer');
      const icon = item.querySelector('.faq-icon');
      
      question?.addEventListener('click', () => {
        const isOpen = question.getAttribute('aria-expanded') === 'true';
        
        // Close all other FAQs
        faqItems.forEach(otherItem => {
          const otherQuestion = otherItem.querySelector('.faq-question');
          const otherAnswer = otherItem.querySelector('.faq-answer');
          const otherIcon = otherItem.querySelector('.faq-icon');
          
          if (otherItem !== item) {
            otherQuestion?.setAttribute('aria-expanded', 'false');
            if (otherAnswer instanceof HTMLElement) {
              otherAnswer.style.maxHeight = '0';
            }
            otherIcon?.classList.remove('rotate-180');
          }
        });
        
        // Toggle current FAQ
        if (isOpen) {
          question.setAttribute('aria-expanded', 'false');
          if (answer instanceof HTMLElement) {
            answer.style.maxHeight = '0';
          }
          icon?.classList.remove('rotate-180');
        } else {
          question.setAttribute('aria-expanded', 'true');
          if (answer instanceof HTMLElement) {
            answer.style.maxHeight = answer.scrollHeight + 'px';
          }
          icon?.classList.add('rotate-180');
        }
      });
    });
  });
</script>
